<component type="desktop">
  <id>ai.solers.Engine</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  <name>Solers Engine</name>
  <summary>AI-native Godot-compatible 2D and 3D game engine</summary>
  <launchable type="desktop-id">ai.solers.Engine.desktop</launchable>
  <description>
    <p>
      Solers is an AI-native, Godot-compatible, multi-platform 2D and 3D game
      engine distribution built for natural-language-driven game creation.
    </p>
    <p>
      Solers preserves standard Godot project compatibility while adding a native
      AI operator layer for scene, script, resource, runtime, and export workflows.
    </p>
  </description>
